# Telegram Bot Token, полученный у @BotFather
BOT_TOKEN=your_bot_token_here

# Строка подключения к БД (async-драйвер обязателен).
# По умолчанию — локальный SQLite-файл.
DATABASE_URL=sqlite+aiosqlite:///./streakbot.db
# Для перехода на PostgreSQL (см. docs/SCALING.md):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/streakbot

# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Файл для записи логов
LOG_FILE=logs/bot.log
